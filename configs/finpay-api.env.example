# finpay-api (gRPC server) - example env

# Server
FINPAY_GRPC_ADDR=:8080
FINPAY_METRICS_ADDR=:2112

# Redis / DB
FINPAY_REDIS_ADDR=redis:6379
FINPAY_DB_DSN=file:/var/lib/finpay/finpay.db

# Idempotency / Replay protection
FINPAY_IDEMPOTENCY_LOCK_TTL=15s
FINPAY_IDEMPOTENCY_CACHE_TTL=10m
FINPAY_NONCE_TTL=10m
FINPAY_TS_SKEW=300s

# Public keys file (ConfigMap mount path)
# This file contains client_id/key_id/public_key_pem/revoked_at etc.
FINPAY_KEYS_FILE=/etc/finpay/client_public_keys.json

# OpenTelemetry (export to otelcol-gateway via OTLP/gRPC)
OTEL_SERVICE_NAME=finpay-api
OTEL_EXPORTER_OTLP_ENDPOINT=otelcol-gateway:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev
